# Optional: override default HTTP server settings.
# Remove .default suffix to enable.

[server]
debug = false
listenerType = "tcp"
listen = ":8080"
readTimeout = 30
writeTimeout = 30
idleTimeout = 120
writeBufferSize = 8192
readBufferSize = 8192
bodyLimit = 1048576
trustedProxies = ["127.0.0.1", "::1"]
